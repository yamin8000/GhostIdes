<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.floatingtoolbar.FloatingToolbarLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="wrap_content"
     android:layout_width="match_parent"
     android:visibility="gone"
     android:elevation="8dp"
     app:marginRightSystemWindowInsets="true"
     android:padding="12dp"
     android:orientation="horizontal"
     app:marginBottomSystemWindowInsets="true"
     android:layout_gravity="bottom|center_horizontal"
     android:gravity="center_vertical"
     android:background="?colorSurface"
     android:layout_marginEnd="8dp"
     android:layout_marginStart="8dp"
     app:marginLeftSystemWindowInsets="true"
     app:marginTopSystemWindowInsets="false"
     android:id="@+id/selectionPanel">

    <LinearLayout
         android:layout_height="wrap_content"
         android:gravity="center_horizontal"
         android:layout_width="match_parent">

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:layout_marginEnd="16dp"
             android:textSize="16sp"
             android:id="@+id/txt_selected_count"
             android:text="0"
             android:textStyle="bold" />

        <ImageView
             android:layout_height="32dp"
             android:layout_width="32dp"
             android:layout_marginEnd="16dp"
             android:tint="?colorOnSurface"
             android:src="@drawable/ic_copy"
             android:id="@+id/btn_copy" />

        <ImageView
             android:layout_height="32dp"
             android:layout_width="32dp"
             android:layout_marginEnd="16dp"
             android:src="@drawable/ic_cut"
             android:tint="?colorOnSurface"
             android:id="@+id/btn_cut" />

        <ImageView
             android:layout_height="32dp"
             android:layout_width="32dp"
             android:layout_marginEnd="16dp"
             android:tint="?colorOnSurface" 
             android:src="@drawable/ic_delete"
             android:id="@+id/btn_delete" />

        <ImageView
             android:layout_height="32dp"
             android:layout_width="32dp"
             android:layout_marginEnd="16dp"
             android:src="@drawable/ic_paste"
             android:tint="?colorOnSurface"
             android:id="@+id/btn_paste" />

        <ImageView
             android:layout_height="32dp"
             android:layout_width="32dp"
             android:tint="?colorOnSurface"
             android:layout_gravity="end"
             android:src="@drawable/ic_close"
             android:id="@+id/btn_close" />

    </LinearLayout>

</com.google.android.material.floatingtoolbar.FloatingToolbarLayout>