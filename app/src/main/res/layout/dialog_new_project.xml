<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Project type selector -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/project_type"
        android:textAppearance="?textAppearanceLabelLarge"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipHtml"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HTML"
            style="@style/Widget.Material3.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipNodejs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Node.js"
            style="@style/Widget.Material3.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipJava"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Java"
            style="@style/Widget.Material3.Chip.Filter" />

    </com.google.android.material.chip.ChipGroup>

    <!-- Project name -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilProjectName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/project_name_hint"
        android:layout_marginBottom="12dp"
        app:endIconMode="clear_text">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etProjectName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:inputType="text" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Package name (Java only) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilPackageName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/project_package_hint"
        android:visibility="gone"
        app:endIconMode="clear_text">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPackageName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:inputType="text"
            android:text="com.example" />

    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
