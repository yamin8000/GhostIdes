<HorizontalScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/panel_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/contextual_magnifier_background"
    tools:theme="@style/Theme.Material3.DayNight">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/panel_btn_expand_selection"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:contentDescription="@string/editor_expand_selection"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_expand_selection" />

        <ImageButton
            android:id="@+id/panel_btn_select_all"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:contentDescription="@string/editor_select_all"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_select_all" />

        <ImageButton
            android:id="@+id/panel_btn_copy"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:contentDescription="@string/editor_copy_text"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_copy_selection" />

        <ImageButton
            android:id="@+id/panel_btn_paste"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:contentDescription="@string/editor_paste_text"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_paste_content" />

        <ImageButton
            android:id="@+id/panel_btn_long_select"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:contentDescription="@string/editor_long_select"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_select_drag" />

        <ImageButton
            android:id="@+id/panel_btn_cut"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:contentDescription="@string/editor_cut_text"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_cut_selection" />

        <ImageButton
            android:id="@+id/panel_btn_format"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:contentDescription="@string/editor_format"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_format_selection"
            android:visibility="gone" />
    </LinearLayout>
</HorizontalScrollView>